# Base de datos - Supabase (gratis hasta 500MB)
# Obtené en: https://supabase.com → New Project → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth - Generá con: openssl rand -base64 32
NEXTAUTH_SECRET="TU_SECRET_RANDOM_AQUI"
NEXTAUTH_URL="http://localhost:3000"
# En producción cambiar a: https://tecnovate.com

# Google OAuth (para login con Google)
# En: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"

# Cloudinary (imágenes de productos - gratis 25GB)
# En: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# PayPal (pagos internacionales)
# En: https://developer.paypal.com → Apps & Credentials
NEXT_PUBLIC_PAYPAL_CLIENT_ID="AZDxjD..."
PAYPAL_CLIENT_SECRET="EGnHDx..."

# Bancard (pagos locales Paraguay)
# Contactar a Bancard: https://bancard.com.py
BANCARD_API_URL="https://vpos.infonet.com.py"
BANCARD_PUBLIC_KEY="tu_public_key"
BANCARD_PRIVATE_KEY="tu_private_key"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
